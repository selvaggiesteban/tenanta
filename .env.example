APP_NAME=Tenanta
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=http://72.60.59.25

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_AR

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tenanta
DB_USERNAME=tenanta
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120

CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@tenanta.com"
MAIL_FROM_NAME="${APP_NAME}"

# JWT Authentication
JWT_SECRET=

# Laravel Reverb (WebSockets)
REVERB_APP_ID=tenanta
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="srv1569965.hstgr.cloud"
REVERB_PORT=8080
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# AI Providers (Agnostic Strategy)
AI_PROVIDER=gemini # Adapter: gemini, openai, claude

# Google (Gemini) - BYOK Model
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro

# OpenAI - BYOK Model
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (Claude) - BYOK Model
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Payment Providers
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
STRIPE_KEY=
STRIPE_SECRET=

# Accountly Microservice Integration
ACCOUNTLY_API_URL=http://accountly-service/api
ACCOUNTLY_API_KEY=
